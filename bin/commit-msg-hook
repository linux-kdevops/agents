#!/bin/bash
# Multi-AI Collaboration Protocol (MACP) - Commit Message Enforcer
# Place in .git/hooks/commit-msg and chmod +x

COMMIT_MSG_FILE=$1

# Read commit message
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check for required MACP fields
check_field() {
    local field=$1
    local pattern=$2
    local example=$3

    if ! echo "$COMMIT_MSG" | grep -q "^$field:"; then
        echo -e "${RED}вќЊ Missing required field: $field${NC}"
        echo -e "${YELLOW}   Example: $field: $example${NC}"
        return 1
    fi

    if [ -n "$pattern" ]; then
        local value=$(echo "$COMMIT_MSG" | grep "^$field:" | cut -d: -f2- | tr -d ' ')
        if [ -z "$value" ] || [ "$value" = "TODO" ] || [ "$value" = "FIXME" ]; then
            echo -e "${RED}вќЊ Field $field has placeholder value: $value${NC}"
            echo -e "${YELLOW}   Must be a real value, not TODO/FIXME${NC}"
            return 1
        fi
    fi

    return 0
}

validate_work_tracker() {
    if ! echo "$COMMIT_MSG" | grep -qE "^Work-(Tracker|Item|Role|Visibility|Resolution):"; then
        return 0
    fi

    local tracker item role visibility resolution
    tracker=$(echo "$COMMIT_MSG" | grep "^Work-Tracker:" | head -1 | cut -d: -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    item=$(echo "$COMMIT_MSG" | grep "^Work-Item:" | head -1 | cut -d: -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    role=$(echo "$COMMIT_MSG" | grep "^Work-Role:" | head -1 | cut -d: -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    visibility=$(echo "$COMMIT_MSG" | grep "^Work-Visibility:" | head -1 | cut -d: -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    resolution=$(echo "$COMMIT_MSG" | grep "^Work-Resolution:" | head -1 | cut -d: -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    if [ -z "$tracker" ] || [ "$tracker" = "TODO" ] || [ "$tracker" = "FIXME" ]; then
        echo -e "${RED}вќЊ Work-* block present but Work-Tracker is missing${NC}"
        ((ERRORS++))
    else
        case "$tracker" in
            linear|github|gitlab|jira|other)
                echo -e "${GREEN}вњ“ Work-Tracker: $tracker${NC}"
                ;;
            *)
                echo -e "${RED}вќЊ Invalid Work-Tracker: $tracker${NC}"
                echo -e "${YELLOW}   Must be: linear, github, gitlab, jira, or other${NC}"
                ((ERRORS++))
                ;;
        esac
    fi

    if [ -z "$item" ] || [ "$item" = "TODO" ] || [ "$item" = "FIXME" ]; then
        echo -e "${RED}вќЊ Work-* block present but Work-Item is missing${NC}"
        ((ERRORS++))
    fi

    if [ -z "$role" ]; then
        echo -e "${RED}вќЊ Work-* block present but Work-Role is missing${NC}"
        ((ERRORS++))
    else
        case "$role" in
            source|handoff|followup|blocked-by|security|release|review|triage)
                echo -e "${GREEN}вњ“ Work-Role: $role${NC}"
                ;;
            *)
                echo -e "${RED}вќЊ Invalid Work-Role: $role${NC}"
                echo -e "${YELLOW}   Must be: source, handoff, followup, blocked-by, security, release, review, or triage${NC}"
                ((ERRORS++))
                ;;
        esac
    fi

    if [ -z "$visibility" ]; then
        echo -e "${RED}вќЊ Work-* block present but Work-Visibility is missing${NC}"
        ((ERRORS++))
    else
        case "$visibility" in
            public|private|private-context|redacted)
                echo -e "${GREEN}вњ“ Work-Visibility: $visibility${NC}"
                ;;
            *)
                echo -e "${RED}вќЊ Invalid Work-Visibility: $visibility${NC}"
                echo -e "${YELLOW}   Must be: public, private, private-context, or redacted${NC}"
                ((ERRORS++))
                ;;
        esac
    fi

    if [ -n "$resolution" ]; then
        case "$resolution" in
            fixed|partial|deferred|wontfix|research|none)
                echo -e "${GREEN}вњ“ Work-Resolution: $resolution${NC}"
                ;;
            *)
                echo -e "${RED}вќЊ Invalid Work-Resolution: $resolution${NC}"
                echo -e "${YELLOW}   Must be: fixed, partial, deferred, wontfix, research, or none${NC}"
                ((ERRORS++))
                ;;
        esac
    fi
}

# Skip check for merge commits
if echo "$COMMIT_MSG" | grep -q "^Merge"; then
    echo -e "${GREEN}вњ“ Merge commit - skipping MACP validation${NC}"
    exit 0
fi

# Skip check if commit message starts with "WIP:" or "fixup!" or "squash!"
if echo "$COMMIT_MSG" | grep -qE "^(WIP:|fixup!|squash!)"; then
    echo -e "${YELLOW}вљ  WIP/fixup/squash commit - skipping MACP validation${NC}"
    exit 0
fi

echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"
echo "рџ¤– Multi-AI Collaboration Protocol (MACP) Validator"
echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"

ERRORS=0

# Check required fields
check_field "AI-Agent" "[A-Za-z-]+" "Claude-Code" || ((ERRORS++))
check_field "AI-Session-ID" ".*" "2025-10-28-143000-Claude-Code" || ((ERRORS++))
check_field "AI-Task-Type" ".*" "implement" || ((ERRORS++))
check_field "AI-Context-Tokens" ".*" "~45000" || ((ERRORS++))
check_field "AI-Handoff-From" ".*" "none" || ((ERRORS++))
check_field "AI-Handoff-To" ".*" "none" || ((ERRORS++))
check_field "AI-Thought-Trace" ".*" "none" || ((ERRORS++))
check_field "Generated-by" ".*" "Claude AI" || ((ERRORS++))
check_field "Signed-off-by" ".*" "Your Name <email@example.com>" || ((ERRORS++))

# Validate AI-Agent value
AI_AGENT=$(echo "$COMMIT_MSG" | grep "^AI-Agent:" | cut -d: -f2- | tr -d ' ')
if [ -n "$AI_AGENT" ]; then
    case "$AI_AGENT" in
        Claude-Code|ChatGPT-Codex|Gemini-CLI)
            echo -e "${GREEN}вњ“ AI-Agent: $AI_AGENT${NC}"
            ;;
        *)
            echo -e "${RED}вќЊ Invalid AI-Agent: $AI_AGENT${NC}"
            echo -e "${YELLOW}   Must be: Claude-Code, ChatGPT-Codex, or Gemini-CLI${NC}"
            ((ERRORS++))
            ;;
    esac
fi

# Validate AI-Task-Type value
AI_TASK_TYPE=$(echo "$COMMIT_MSG" | grep "^AI-Task-Type:" | cut -d: -f2- | tr -d ' ')
if [ -n "$AI_TASK_TYPE" ]; then
    case "$AI_TASK_TYPE" in
        design|implement|debug|refactor|test|build|docs)
            echo -e "${GREEN}вњ“ AI-Task-Type: $AI_TASK_TYPE${NC}"
            ;;
        *)
            echo -e "${RED}вќЊ Invalid AI-Task-Type: $AI_TASK_TYPE${NC}"
            echo -e "${YELLOW}   Must be: design, implement, debug, refactor, test, build, or docs${NC}"
            ((ERRORS++))
            ;;
    esac
fi

# Check for shopping list anti-pattern (bulleted lists in commit body)
if echo "$COMMIT_MSG" | grep -qE "^[-*] "; then
    echo -e "${YELLOW}вљ  Warning: Commit body contains bullet points${NC}"
    echo -e "${YELLOW}   MACP prefers plain English explanations over shopping lists${NC}"
    echo -e "${YELLOW}   This is a warning, not an error (commit will proceed)${NC}"
fi

validate_work_tracker

# Check for "Generated-by" and "Signed-off-by" order
GENBY_LINE=$(echo "$COMMIT_MSG" | grep -n "^Generated-by:" | cut -d: -f1)
SIGNOFF_LINE=$(echo "$COMMIT_MSG" | grep -n "^Signed-off-by:" | cut -d: -f1)

if [ -n "$GENBY_LINE" ] && [ -n "$SIGNOFF_LINE" ]; then
    if [ $((SIGNOFF_LINE - GENBY_LINE)) -ne 1 ]; then
        echo -e "${RED}вќЊ Generated-by and Signed-off-by must be consecutive lines${NC}"
        echo -e "${YELLOW}   Generated-by must be immediately followed by Signed-off-by${NC}"
        ((ERRORS++))
    else
        echo -e "${GREEN}вњ“ Generated-by and Signed-off-by are consecutive${NC}"
    fi
fi

echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}вќЊ MACP validation FAILED with $ERRORS error(s)${NC}"
    echo ""
    echo "Your commit message must include ALL required MACP fields."
    echo "See ~/devel/agents/README.md for examples and documentation."
    echo ""
    echo "Quick fix template:"
    echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"
    echo "subject: your commit message"
    echo ""
    echo "Detailed description of changes..."
    echo ""
    echo "AI-Agent: Claude-Code"
    echo "AI-Session-ID: \$(date +%Y-%m-%d-%H%M%S)-Claude-Code"
    echo "AI-Task-Type: implement"
    echo "AI-Context-Tokens: ~10000"
    echo "AI-Handoff-From: none"
    echo "AI-Handoff-To: none"
    echo "AI-Thought-Trace: none"
    echo ""
    echo "Generated-by: Claude AI"
    echo "Signed-off-by: Your Name <email@example.com>"
    echo "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ"
    exit 1
fi

echo -e "${GREEN}вњ… MACP validation PASSED${NC}"

# Log to session file if it exists
if [ -f ".ai-traces/sessions.log" ]; then
    SESSION_ID=$(echo "$COMMIT_MSG" | grep "^AI-Session-ID:" | cut -d: -f2- | tr -d ' ')
    AI_AGENT=$(echo "$COMMIT_MSG" | grep "^AI-Agent:" | cut -d: -f2- | tr -d ' ')
    TASK_TYPE=$(echo "$COMMIT_MSG" | grep "^AI-Task-Type:" | cut -d: -f2- | tr -d ' ')
    TOKENS=$(echo "$COMMIT_MSG" | grep "^AI-Context-Tokens:" | cut -d: -f2- | tr -d ' ~')

    TIMESTAMP=$(date -Iseconds)
    echo "[$TIMESTAMP] [$AI_AGENT] [$SESSION_ID] COMMIT task=$TASK_TYPE tokens=$TOKENS" >> .ai-traces/sessions.log
fi

exit 0
